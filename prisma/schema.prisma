generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Appointment {
  id       String  @id @unique @default(cuid())
  start    Int
  duration Int     @default(30)
  client   Client? @relation(fields: [clientId], references: [id])
  clientId String?
}

model Client {
  id          String        @id @unique @default(cuid())
  firstName   String
  appointment Appointment[]

  @@unique([firstName])
}
